<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.jonisport"
       name="JoniSport"
       version="1.0.0"
       provider-name="JoniSport">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.pluginsource"
               library="default.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>JoniSport Kodi Add-on</summary>
        <description>Official JoniSport Add-on</description>
        <platform>all</platform>
    </extension>

</addon>
